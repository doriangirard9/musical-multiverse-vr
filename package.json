{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "HTTPS=true vite --host",
    "server": "cd server-config; node server.js",
    "all": "concurrently --handleInput --prefixColors red,green \"npm run server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "build:prod": "vite build --mode production --no-emptyOutDir",
    "preview": "vite preview",
    "docs": "typedoc",
    "update_package_locks": "npm i --package-lock-only; pnpm import"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@webaudiomodules/api": "^2.0.0-alpha.6",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  },
  "dependencies": {
    "@babylonjs/core": "^8.24.0",
    "@babylonjs/gui": "^8.24.0",
    "@babylonjs/havok": "^1.3.10",
    "@babylonjs/inspector": "^8.24.0",
    "@babylonjs/loaders": "^8.24.0",
    "@babylonjs/materials": "^8.24.0",
    "@webaudiomodules/sdk": "^0.0.12",
    "concurrently": "^9.2.1",
    "tone": "^15.0.4",
    "uuid": "^11.1.0",
    "wam3dgenerator": "github:Jempasam/3d_wam_editor#semver:0.0.7",
    "ws": "^8.18.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.24"
  }
}
